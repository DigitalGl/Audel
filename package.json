{
  "name": "audel",
  "productName": "Audel",
  "version": "1.1.3",
  "description": "Audel local desktop music player",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dist": "electron-builder",
    "postinstall": "node scripts/fetch-ytdlp.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.audel.player",
    "productName": "Audel",
    "copyright": "Copyright (c) 2026 Audel",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "LICENSE",
      "package.json",
      ".puppeteerrc.cjs",
      "build/icon.png",
      "build/icon.svg",
      "chromium-bundle/**",
      "yt-dlp-bundle/**"
    ],
    "asarUnpack": [
      "chromium-bundle/**",
      "yt-dlp-bundle/**",
      "node_modules/ffmpeg-static/**"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icons",
      "category": "AudioVideo;Audio;Player",
      "synopsis": "Minimal desktop music player",
      "description": "Audel is a minimal local music player built with Electron.",
      "desktop": {
        "entry": {
          "StartupWMClass": "audel"
        }
      }
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.music",
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": "Audel",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "music-metadata": "^11.12.3",
    "node-id3": "^0.2.9",
    "puppeteer": "^23.11.1"
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  }
}
